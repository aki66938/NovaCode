{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovaCode",
  "version": "0.1.1",
  "identifier": "com.novacode.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NovaCode",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGRUFEODM2MTc3N0UzQUMKUldTczQzY1hOdGpxZjNJSEV3b2JGSDc3QkVYN2JMdmpicXRleFpweDcydDNmZlFFd3RBYkt1U0wK",
      "endpoints": [
        "https://github.com/aki66938/NovaCode/releases/latest/download/latest.json"
      ]
    }
  }
}
